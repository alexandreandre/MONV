# =============================================================================
# MONV — .gitignore racine (sécurité + Python + Node/Next + outils)
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets et configuration locale (ne jamais versionner)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
!.env.template
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.secret
*.secrets
secrets.yaml
secrets.yml
credentials.json
service-account*.json
*-credentials.json
.aws/credentials
.netrc

# -----------------------------------------------------------------------------
# Python / FastAPI (backend)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
# Paquets / builds Python (éviter `lib/` : conflit avec p.ex. frontend/src/lib)
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
sdist/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log
htmlcov/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/
.ruff_cache/
.python-version
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
*.sqlite
*.sqlite3
*.db

# -----------------------------------------------------------------------------
# Node.js / Next.js (frontend)
# -----------------------------------------------------------------------------
node_modules/
jspm_packages/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
.eslintcache
.stylelintcache
.parcel-cache
.next/
out/
.nuxt/
.svelte-kit/
.vercel
.turbo
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Éditeurs et IDE
# -----------------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
*.swp
*.swo
*~
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# -----------------------------------------------------------------------------
# Système d'exploitation
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Exports applicatifs (MONV)
# -----------------------------------------------------------------------------
backend/exports/

# Données locales / exports hors dépôt
prospection_pme.xlsx

# -----------------------------------------------------------------------------
# Logs et fichiers temporaires
# -----------------------------------------------------------------------------
logs/
*.log
tmp/
temp/
*.tmp
*.temp
*.bak
*.orig

# -----------------------------------------------------------------------------
# Docker / infra locale (optionnel)
# -----------------------------------------------------------------------------
*.local.yml
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Outils divers
# -----------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
.ansible/
vault_pass.txt
