# ─── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...                     # anon / public key
SUPABASE_SERVICE_KEY=eyJ...             # service_role key (obligatoire côté backend pour la base)

# Schéma SQL : exécute une fois `supabase/migrations/001_schema.sql` dans le SQL Editor Supabase.

# ─── OpenRouter ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

FILTER_MODEL=google/gemini-flash-1.5
GUARD_MODEL=anthropic/claude-3.5-haiku
ORCHESTRATOR_MODEL=anthropic/claude-3.5-sonnet
# Atelier (création business) : plan stratégique + dossier. Si vide → ORCHESTRATOR_MODEL.
# ATELIER_BUSINESS_MODEL=anthropic/claude-3.5-sonnet

# ─── Google Places (recommandé) ──────────────────────────────────────────────
# Clé API avec l'API « Places (New) » activée — console.cloud.google.com/apis
# Permet de trouver des commerces/boutiques de niche introuvables via SIRENE seul.
GOOGLE_PLACES_API_KEY=

# ─── Pappers (optionnel) ─────────────────────────────────────────────────────
# Par défaut l’URL est api.pappers.in (international, en-tête api-key). Une clé invalide → 401, pas de fusion Pappers.
# Pour l’API France classique : PAPPERS_BASE_URL=https://api.pappers.fr/v2 (voir doc Pappers).
PAPPERS_API_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=true
# Production : URL(s) du frontend autorisées pour CORS (virgules). Si vide : localhost + SITE_URL.
# CORS_ORIGINS=https://app.example.com,https://www.example.com
# true uniquement pour tests CI sans Supabase (jamais en prod).
# SKIP_DB_VERIFY_ON_STARTUP=false
# Emails séparés par des virgules : export sans débit, solde API « illimité » (dev / comptes internes)
# UNLIMITED_CREDITS_EMAILS=toi@example.com
# true = traces [MONV.pipeline] sur stderr (même terminal que uvicorn)
# Lance uvicorn depuis le dossier ``backend/`` pour que le ``.env`` soit lu (config ``env_file``).
PIPELINE_DEBUG=false
